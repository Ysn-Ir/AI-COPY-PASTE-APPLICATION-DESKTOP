# ClipboardAI — environment file
# Copy this file to .env and fill in your API keys via the app's API Keys tab,
# or paste them here directly.

# Google Gemini (Recommended — generous free tier)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Free tier, very fast inference)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI or compatible (e.g. local Ollama)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Override base URL for local / self-hosted models (optional)
# OPENAI_BASE_URL=http://localhost:11434/v1
